# Cora AI OS — environment configuration
# Copy to .env and fill in real values. Do not commit .env.

# Runtime mode: development | staging | production
CORA_ENV=production

# Postgres DSN. Hostname must resolve on the cora-internal network.
DATABASE_URL=postgresql://cora:change-me@postgres:5432/cora

# Redis connection URL. Hostname must resolve on the cora-internal network.
REDIS_URL=redis://redis:6379/0

# DGX Spark inference endpoint (leave blank until wired up).
DGX_MODEL_ENDPOINT=

# Optional log verbosity for cora-api (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# Credential Vault v0.6 — Fernet key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CORA_CREDENTIAL_ENC_KEY=

# External Execution Kill Switch v0.8 — global master gate for ALL external
# provider execution (email send / calendar create / any provider call). MUST
# stay false in this phase; the system is dry-run / readiness-only.
EXTERNAL_EXECUTION_ENABLED=false

# Real OAuth Flow v1.1 — provider OAuth client config. Leave blank to keep the
# provider "not_configured" (no OAuth flow can start). Connecting an account
# does NOT enable execution (still blocked by the kill switch above). Tokens are
# encrypted at rest with CORA_CREDENTIAL_ENC_KEY.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=
